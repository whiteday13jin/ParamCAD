      "inner_diameter": 118,
      "plate_thickness": 20,
      "hole_count": 4,
      "hole_diameter": 4,
      "hole_spacing": 145,
      "boss_height": 10
    },
    "bounds": {
      "outer_diameter": { "min": 140, "max": 1000 },
      "inner_diameter": { "min": 110, "max": 900 },
      "plate_thickness": { "min": 8, "max": 120 },
      "hole_count": { "min": 1, "max": 120 },
      "hole_diameter": { "min": 1, "max": 80 },
      "hole_spacing": { "min": 120, "max": 400 },
      "boss_height": { "min": 0, "max": 40 }
    },
    "summary_keys": ["outer_diameter", "inner_diameter", "hole_diameter", "hole_count"]
  },
  "sheet_metal_cover": {
    "display_name": "Sheet Metal Cover",
