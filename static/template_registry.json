{
  "motor_mount_bracket": {
    "display_name": "Motor/Gearbox Mount Bracket",
    "macro_template": "motor_mount_bracket.vba",
    "model_template": "motor_mount_bracket.SLDPRT",
    "support_level": "partial",
    "llm_ready": true,
    "status_notes": [
      "当前优先支持长度、宽度、高度、板厚、孔径、孔距。",
      "当前模型实质上按固定 4 孔布局工作，length、hole_spacing、hole_diameter 之间存在联动约束。",
      "按当前 4 孔布局，经验上需满足：length >= 3 * hole_spacing + 3 * hole_diameter。",
      "上述可见参数已做真实生成扫描，当前表现稳定。",
      "孔数量与圆角半径尚未稳定接入执行器，暂不建议作为首个 LLM 模板。"
    ],
    "required": [
      "length",
      "width",
      "height",
      "plate_thickness",
      "hole_diameter",
      "hole_count",
      "hole_spacing"
    ],
    "defaults": {
      "length": 120,
      "width": 60,
      "height": 70,
      "plate_thickness": 6,
      "hole_diameter": 6,
      "hole_count": 4,
      "hole_spacing": 30,
      "fillet_radius": 3
    },
    "bounds": {
      "length": { "min": 40, "max": 2000 },
      "width": { "min": 20, "max": 1000 },
      "height": { "min": 20, "max": 800 },
      "plate_thickness": { "min": 1, "max": 50 },
      "hole_diameter": { "min": 1, "max": 80 },
      "hole_count": { "min": 1, "max": 100 },
      "hole_spacing": { "min": 1, "max": 300 },
      "fillet_radius": { "min": 0, "max": 100 }
    },
    "summary_keys": ["length", "width", "height", "hole_diameter", "hole_spacing"]
  },
